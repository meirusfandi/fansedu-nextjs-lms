# Contoh variabel environment. Copy ke .env.local untuk override lokal (jangan commit .env.local).
# Next.js otomatis memakai:
#   - .env.development saat npm run dev (local)
#   - .env.production saat npm run build (server)

# URL backend API (tanpa trailing slash)
# Production:
NEXT_PUBLIC_API_URL=https://api.fansedu.web.id

# Development lokal — uncomment dan pastikan server Go berjalan di port 8080:
# NEXT_PUBLIC_API_URL=http://localhost:8080

# URL platform belajar untuk siswa/guru (setelah login role siswa/teacher diarahkan ke sini)
# NEXT_PUBLIC_LANDING_URL=https://belajar.fansedu.web.id
